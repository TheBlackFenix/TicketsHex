ASPNETCORE_ENVIRONMENT=Production
ConnectionStrings__DefaultConnection=Host=postgres;Port=5432;Database=ticketshex;Username=ticketshex;Password=change-me
Jwt__Issuer=https://ticketshex.example.com
Jwt__Audience=TicketsHex.API
