{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "TicketsHex.API/Dockerfile",
    "watchPatterns": [
      "/TicketsHex.API/**",
      "/TicketsHex.Application/**",
      "/TicketsHex.Domain/**",
      "/TicketsHex.infrastructure/**",
      "/railway.json"
    ]
  },
  "deploy": {
    "healthcheckPath": "/health",
    "healthcheckTimeout": 120,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
